{
    "name": "Python 3.12 Skipslides",
    
    // Build from your custom Dockerfile
    "build": { "dockerfile": "Dockerfile" },

    // Automatically install Python dependencies
    "postCreateCommand": "pip install -r requirements.txt",

    // Forward ports for notebooks or local servers
    "forwardPorts": [8888, 5000],

    // VS Code extensions to install in container
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ]
        }
    }

    // Optional root user
    // "remoteUser": "root"
}